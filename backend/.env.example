# --- Base de données Supabase ---
# Runtime (Transaction pooler, port 6543)
DATABASE_URL="postgresql://postgres.xxxx:PASSWORD@aws-x.pooler.supabase.com:6543/postgres"
# Migrations (Session pooler / direct, port 5432)
DIRECT_URL="postgresql://postgres.xxxx:PASSWORD@aws-x.pooler.supabase.com:5432/postgres"

# --- Sécurité ---
JWT_SECRET="chaine-longue-et-aleatoire-min-32-caracteres"
# En production, liste blanche des origines autorisées (séparées par des virgules). Vide = ouvert.
CORS_ORIGINS=""

# --- TMDB (obligatoire) ---
TMDB_API_KEY="ta-cle-tmdb"

# --- Email de vérification (optionnel : sinon le lien est logué en console) ---
RESEND_API_KEY=""
MAIL_FROM="Neptune <onboarding@resend.dev>"
# URL publique du backend (pour construire le lien de vérification)
PUBLIC_URL="https://ton-service.onrender.com"

# --- Modération IA des avatars (optionnel) ---
SIGHTENGINE_API_USER=""
SIGHTENGINE_API_SECRET=""

# --- Divers ---
PORT="3000"

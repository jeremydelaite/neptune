# PostgreSQL (Supabase ou Neon — copier l'URL de connexion "pooling")
DATABASE_URL="postgresql://user:password@host:5432/neptune"

# Secret JWT (générer avec : openssl rand -base64 32)
JWT_SECRET="change-me"

# Clé API TMDB (gratuite : https://www.themoviedb.org/settings/api)
TMDB_API_KEY="votre-cle-tmdb"

PORT=3000
